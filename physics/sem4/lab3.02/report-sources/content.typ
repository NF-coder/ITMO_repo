#block()[
  = Результаты прямых измерений и их обработки
  
  == Расчёт параметров цепи <параметры_цепи>
  По данным из @table:results_of_experiment построим график зависимости напряжения ($U$) от тока ($I$) с помощью МНК ($U=k I + b$) (см. @fig:voltage_and_amperage).\
  Вычислим угловой коэффициент ($k$), модуль значения которого соответствует значению внутреннего сопротивления:
  $
    overline(U) approx 7.68 "В" quad overline(I) approx 4.41 "мА"\
    k = (sum_(i=1)^N (I_i - overline(I))(U_i - overline(U)))/(sum_(i=1)^N (I_i - overline(I))^2) =
    (sum_(i=1)^15 (I_i - 4.41)(U_i - 7.68))/(sum_(i=1)^15 (I_i - 4.41)^2)  approx -0.62 space "В"/"мА"\
  $
  $
    r = abs(k) = abs(-0.62) = 0.62 "кОм"
  $
  Затем вычислим смещение ($b$), соответствующее значению ЭДС ($epsilon$):
  $
    epsilon = b = overline(U) - overline(I) k = 7.68 - 4.41 dot (-0.62) approx 9.19 "В"
  $
  Визуально зависимость схожа с линейной.
]
#block()[
  = Результаты косвенных измерений и их обработка
  == Нахождение мощности
  Используя данные из таблицы и найденные в @параметры_цепи значения заполним колонки полезной, теоретической и мощности потерь, используя следующие формулы:
  $
    "Полезная мощность" P_R = U I\
    "Теоретическая мощность" P = epsilon I\
    "Мощность потерь" P_S = I^2 r
  $
  Занесём полученные значения в соответствующие колонки таблицы

  == Построение графиков и поиск оптимальных значений
  По данным из @table:results_of_experiment построим график зависимости всех найденных ранее мощностей (см. @fig:power).\
  По нему же видно, что максимальная полезная мощность достигается при силе тока:
  $
    I^* = 7.40 "мА"
  $
  
  == Найдём ток согласования источника и нагрузки
  Подставим в формулу полезной мощности значения $𝑃_(𝑅_"𝑚𝑎𝑥")$ и $𝐼^*$
  $
    𝑃_𝑅_"max" = 𝐼^2 𝑅_"max"\ 
    34.19 = (7.40)^2 dot R_"max"\
    R_"max" approx 0.62 "кОм"
  $
  Полученное сопротивление режима согласования нагрузки и источника отличается от найденного с помощью МНК на
  $
    Delta 𝑅_"𝑚𝑎𝑥" = abs(r  - 𝑅_"𝑚𝑎𝑥") = abs(0.62 - 0.62) approx 0.20 dot 10^(-1) "кОм"\
    epsilon_(𝑅_"𝑚𝑎𝑥") = (Delta 𝑅_"𝑚𝑎𝑥")  /  𝑅_"𝑚𝑎𝑥" dot 100% = (0.20 dot 10^(-1))/0.62 dot 100% approx 5.86 dot 10^(-3) space% 
  $

  == Зависимость КПД от силы тока
  По данным из @table:results_of_experiment построим график зависимости КПД от силы тока с помощью МНК ($eta = k I + b$) (см. @fig:kpd_and_amperage).\
  $
    overline(eta) approx 0.48 quad overline(I) approx 4.41 "мА"\
    k = (sum_(i=1)^N (I_i - overline(I))(eta_i - overline(eta)))/(sum_(i=1)^N (I_i - overline(I))^2) =
    (sum_(i=1)^15 (I_i -  4.41)(eta_i -  0.48))/(sum_(i=1)^15 (I_i -  4.41)^2)
    approx -0.07 space "мА"^(-1)\
    b =  overline(eta) - overline(I) k = 0.48 - 4.41 dot (-0.07) approx 1.00
  $
  Определим значение тока, при котором $eta = 0.5$:
  $
    I^*_0.5 = (eta - b)/k = (0.5 - 1.00)/(-0.07) approx 7.39 "мА"
  $
  Оценим разницу с полученным ранее значением $I^*$
  $
    Delta I^* = abs(I^* -  I^*_0.5 ) = abs(7.40 - 7.39) approx 0.01 "мА"\
    epsilon_(I^*) = (Delta I^*) / (I^*) dot 100%= 0.01/7.40 dot 100%= 0.19 %
  $
]
#block()[
  = Расчет погрешностей измерений

  == Погрешность внутреннего сопротивления
    $ 
      Delta r = 2 sqrt((sum_(i=1)^n (U_i - (epsilon - I_i dot r))^2) / ((n-2) sum_(i=1)^n (I_i - overline(I))^2)) =\
      2 sqrt((sum_(i=1)^15 (U_i - (9.19 - I_i dot 0.62) )^2) / ((15-2) sum_(i=1)^15 (I_i - 4.41)^2)) approx 0.02 "кОм" \
    $
    $
      epsilon_r = (Delta r)/r dot 100% = (0.02)/(0.62) dot 100% approx 3.12%
    $

  == Погрешность ЭДС
    $
      Delta epsilon = 2 sqrt((sum_(i=1)^n (U_i - (epsilon - I_i dot r))^2) / (n-2) dot (1/n + overline(I)^2 / (sum_(i=1)^n (I_i - overline(I))^2))) =\
      = 2 sqrt(
        (sum_(i=1)^15(U_i - (9.19 - I_i dot 0.62))^2)/(15-2) dot
        (1/15 + 4.41^2/(sum_(i=1)^n (I_i - 4.41)^2))
      ) approx 0.16 space В
    $
    $
      epsilon_epsilon = (Delta epsilon)/epsilon dot 100% = (0.16)/(9.19) dot 100% approx 1.72%
    $
]
