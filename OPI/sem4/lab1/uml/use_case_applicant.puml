@startuml applicant
skinparam actorStyle awesome
left to right direction

actor "Неавторизованный\nпользователь" as Guest
actor "Соискатель" as Applicant

Guest <|-- Applicant

rectangle "Подсистема поиска и просмотра" {
  usecase "UC1\nПоиск вакансий\nпо параметрам" as Search
  usecase "UC2\nПросмотр карточки\nвакансии" as ViewVacancy
}

rectangle "Подсистема соискателя" {
  usecase "UC5\nСоздание\nрезюме" as CreateResume
  usecase "UC6\nПубликация\nрезюме" as PublishResume
  usecase "UC7\nОтклик\nна вакансию" as Respond
  usecase "UC8\nПросмотр истории\nоткликов" as History
  usecase "UC9\nУправление\nизбранным" as Favorite
  usecase "UC10\nПодписка на\nпоисковые запросы" as Subscribe
}

 CreateResume .> Respond : <<include>>
Search .up.> Subscribe : <<extend>>
 CreateResume .up.> PublishResume : <<include>>


 Search .down.> Respond : <<extend>>
 ViewVacancy .> Respond : <<extend>>
 ViewVacancy .> Favorite : <<extend>>
 Search ..> ViewVacancy : <<extend>>

Applicant --> CreateResume
Applicant --> PublishResume
Applicant --> History
Applicant --> Favorite
Applicant --> Search
Applicant --> ViewVacancy

@enduml